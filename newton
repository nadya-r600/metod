#include <iostream>
#include <cmath>
#include <iomanip>

using namespace std;

// Функция f(x1, x2)
double f(double x1, double x2) {
    return 3 * x1 * x1 + 2 * x2 * x1 + x2 * x2 - 8 * x1 - 12 * x2;
}

// Градиент
void gradient(double x1, double x2, double grad[2]) {
    grad[0] = 6 * x1 + 2 * x2 - 8;
    grad[1] = 2 * x1 + 2 * x2 - 12;
}

// Матрица Гессе 
void hessian(double H[2][2]) {
    H[0][0] = 6; H[0][1] = 2;
    H[1][0] = 2; H[1][1] = 2;
}

// Обратная матрица Гессе 
void hessianInverse(double Hinv[2][2]) {
    double det = 6 * 2 - 2 * 2; // = 8
    Hinv[0][0] = 2.0 / det; // 0.25
    Hinv[0][1] = -2.0 / det; // -0.25
    Hinv[1][0] = -2.0 / det; // -0.25
    Hinv[1][1] = 6.0 / det; // 0.75
}

double grad_norm(double v[2]) {
    return sqrt(v[0] * v[0] + v[1] * v[1]);
}

// Проверка что матрица положительна
bool Positive(double Hinv[2][2]) {

    double detHinv = Hinv[0][0] * Hinv[1][1] - Hinv[0][1] * Hinv[1][0];
    return (Hinv[0][0] > 0) && (detHinv > 0);
}

int main() {
    setlocale(LC_ALL, "Russian");
    //Шаг 1
    double eps1 = 0.1;
    double eps2 = 0.15;
    int M = 10;
    double x[2] = { 1.0, 2.0 };
    //Шаг 2
    int k = 0;
    double H[2][2];
    double Hinv[2][2];
    double d[2];
    double x_next[2];

    cout << "Начальная точка: x0 = [" << x[0] << ", " << x[1] << "]" << endl;
    cout << "f(x0) = " << f(x[0], x[1]) << endl;

    while (k < M) {
        // Шаг 3
        double grad[2];
        gradient(x[0], x[1], grad);
        cout << "Итерация " << k << ":" << endl;
        cout << "  x^k = [" << x[0] << ", " << x[1] << "]" << endl;
        cout << "  grad f(x^k) = [" << grad[0] << ", " << grad[1] << "]" << endl;
        cout << "  ||grad|| = " << grad_norm(grad) << endl;

        // Шаг 4
        if (grad_norm(grad) <= eps1) {
            cout << "  ||grad|| <= eps1 (" << eps1 << ") -> останов" << endl;
            break;
        }

        // Шаг 5
        if (k >= M) {
            cout << "  k >= M (" << M << ") -> остановка" << endl;
            break;
        }

        // Шаг 6
        hessian(H);

        // Шаг 7
        hessianInverse(Hinv);

        // Шаг 8
        bool Pos = Positive(Hinv);
        cout << "  Hinv > 0? " << (Pos ? "Да" : "Нет") << endl;

        if (Pos) {
            // Шаг 9
            d[0] = -(Hinv[0][0] * grad[0] + Hinv[0][1] * grad[1]);
            d[1] = -(Hinv[1][0] * grad[0] + Hinv[1][1] * grad[1]);
            cout << " d^k = -H^(-1)*grad = [" << d[0] << ", " << d[1] << "]^T" << endl;

            // Шаг 10
            double t = 1.0;
            x_next[0] = x[0] + t * d[0];
            x_next[1] = x[1] + t * d[1];
        }
        else {
            // Шаг 8(б)
            d[0] = -grad[0];
            d[1] = -grad[1];
            cout << "  Hinv < 0: d^k = [" << d[0] << ", " << d[1] << "]" << endl;

        }

        cout << "  x^{k+1} = [" << x_next[0] << ", " << x_next[1] << "]^T" << endl;
        cout << "  f(x^{k+1}) = " << f(x_next[0], x_next[1]) << endl;

        // Шаг 11
        double dx_norm = sqrt((x_next[0] - x[0]) * (x_next[0] - x[0]) + (x_next[1] - x[1]) * (x_next[1] - x[1]));
        double df = fabs(f(x_next[0], x_next[1]) - f(x[0], x[1]));
        cout << "  ||x^{k+1} - x^k|| = " << dx_norm << " < eps2? " << (dx_norm < eps2 ? "Да" : "Нет") << endl;
        cout << "  |f^{k+1} - f^k| = " << df << " < eps2? " << (df < eps2 ? "Да" : "Нет") << endl;

        if (dx_norm < eps2 && df < eps2) {
            cout << "  Оба условия выполнены -> остановка" << endl;
            break;
        }

        x[0] = x_next[0];
        x[1] = x_next[1];
        k++;
    }
