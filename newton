#include <iostream>
#include <cmath>

using namespace std;

// Функция f(x1, x2)
double f(double x1, double x2) {
    return 3 * x1 * x1 + 2 * x2 * x1 + x2 * x2 - 8 * x1 - 12 * x2;
}

// Градиент: grad[0] = df/dx1, grad[1] = df/dx2
void gradient(double x1, double x2, double grad[2]) {
    grad[0] = 6 * x1 + 2 * x2 - 8;
    grad[1] = 2 * x1 + 2 * x2 - 12;
}

// Матрица Гессе (постоянная)
void hessian(double H[2][2]) {
    H[0][0] = 6; H[0][1] = 2;
    H[1][0] = 2; H[1][1] = 2;
}

// Обратная матрица Гессе (заранее вычислена)
void hessianInverse(double Hinv[2][2]) {
    double det = 6 * 2 - 2 * 2; // = 8
    Hinv[0][0] = 2.0 / det; // 0.25
    Hinv[0][1] = -2.0 / det; // -0.25
    Hinv[1][0] = -2.0 / det; // -0.25
    Hinv[1][1] = 6.0 / det; // 0.75
}

// Норма вектора
double norm(double v[2]) {
    return sqrt(v[0] * v[0] + v[1] * v[1]);
}

// Проверка положительной определённости Hinv (по критерию Сильвестра)
bool isPositiveDefinite(double Hinv[2][2]) {
    // Для положительной определённости Hinv нужно, чтобы H была полож. опр.
    // H постоянна: det(H)=8>0, H[0][0]=6>0 => H полож. опр. => Hinv тоже.
    // Но для демонстрации проверим главные миноры Hinv:
    // Минор 1x1: Hinv[0][0] = 0.25 > 0
    // Минор 2x2: det(Hinv) = 1/det(H) = 1/8 = 0.125 > 0
    double detHinv = Hinv[0][0] * Hinv[1][1] - Hinv[0][1] * Hinv[1][0];
    return (Hinv[0][0] > 0) && (detHinv > 0);
}

int main() {
    setlocale(LC_ALL, "Russian");
    // Параметры алгоритма
    double eps1 = 0.1;
    double eps2 = 0.15;
    int M = 10;

    // Начальная точка
    double x[2] = { 1.0, 2.0 };

    int k = 0;
    double grad[2];
    double H[2][2];
    double Hinv[2][2];
    double d[2];
    double x_next[2];

    cout << "Начальная точка: x0 = [" << x[0] << ", " << x[1] << "]^T" << endl;
    cout << "f(x0) = " << f(x[0], x[1]) << endl;
    cout << "----------------------------------------" << endl;

    while (k < M) {
        // Шаг 3: Вычисляем градиент
        gradient(x[0], x[1], grad);
        cout << "Итерация " << k << ":" << endl;
        cout << "  x^k = [" << x[0] << ", " << x[1] << "]^T" << endl;
        cout << "  grad f(x^k) = [" << grad[0] << ", " << grad[1] << "]^T" << endl;
        cout << "  ||grad|| = " << norm(grad) << endl;

        // Шаг 4: Проверка критерия окончания по градиенту
        if (norm(grad) <= eps1) {
            cout << "  ||grad|| <= eps1 (" << eps1 << ") -> останов" << endl;
            break;
        }

        // Шаг 5: Проверка по числу итераций
        if (k >= M) {
            cout << "  k >= M (" << M << ") -> останов" << endl;
            break;
        }

        // Шаг 6: Вычисляем матрицу Гессе
        hessian(H);

        // Шаг 7: Вычисляем обратную матрицу Гессе
        hessianInverse(Hinv);

        // Шаг 8: Проверяем положительную определённость Hinv
        bool isPosDef = isPositiveDefinite(Hinv);
        cout << "  Hinv > 0? " << (isPosDef ? "Да" : "Нет") << endl;

        if (isPosDef) {
            // Шаг 9: d = -H^(-1) * grad
            d[0] = -(Hinv[0][0] * grad[0] + Hinv[0][1] * grad[1]);
            d[1] = -(Hinv[1][0] * grad[0] + Hinv[1][1] * grad[1]);
            cout << "  Направление d^k = -H^(-1)*grad = [" << d[0] << ", " << d[1] << "]^T" << endl;

            // Шаг 10: шаг t_k = 1 (метод Ньютона)
            double t = 1.0;
            x_next[0] = x[0] + t * d[0];
            x_next[1] = x[1] + t * d[1];
        }
        else {
            // Шаг 8(б): градиентный спуск
            d[0] = -grad[0];
            d[1] = -grad[1];
            cout << "  Hinv < 0: d^k = [" << d[0] << ", " << d[1] << "]^T" << endl;

            // Шаг 10: простейший подбор t для уменьшения функции
            double t = 1.0;
            double f_curr = f(x[0], x[1]);
            x_next[0] = x[0] + t * d[0];
            x_next[1] = x[1] + t * d[1];

            // Уменьшаем t, пока f не уменьшится (до 10 попыток)
            int attempts = 0;
            while (f(x_next[0], x_next[1]) >= f_curr && attempts < 10) {
                t *= 0.5;
                x_next[0] = x[0] + t * d[0];
                x_next[1] = x[1] + t * d[1];
                attempts++;
            }
            cout << "  Подобран t = " << t << endl;
        }

        cout << "  x^{k+1} = [" << x_next[0] << ", " << x_next[1] << "]^T" << endl;
        cout << "  f(x^{k+1}) = " << f(x_next[0], x_next[1]) << endl;

        // Шаг 11: Проверка условий окончания по x и f
        double dx_norm = sqrt((x_next[0] - x[0]) * (x_next[0] - x[0]) + (x_next[1] - x[1]) * (x_next[1] - x[1]));
        double df = fabs(f(x_next[0], x_next[1]) - f(x[0], x[1]));
        cout << "  ||x^{k+1} - x^k|| = " << dx_norm << " < eps2? " << (dx_norm < eps2 ? "Да" : "Нет") << endl;
        cout << "  |f^{k+1} - f^k| = " << df << " < eps2? " << (df < eps2 ? "Да" : "Нет") << endl;

        if (dx_norm < eps2 && df < eps2) {
            cout << "  Оба условия выполнены -> останов" << endl;
            break;
        }

        // Переход к следующей итерации
        x[0] = x_next[0];
        x[1] = x_next[1];
        k++;
        cout << "----------------------------------------" << endl;
    }

    cout << "========================================" << endl;
    cout << "Результат: x* = [" << x[0] << ", " << x[1] << "]^T" << endl;
    cout << "f(x*) = " << f(x[0], x[1]) << endl;

    return 0;
}
