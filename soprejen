#include <iostream>
#include <cmath>
#include <iomanip>

using namespace std;

// Функция
double f(double x1, double x2) {
    return 3 * x1 * x1 + 2 * x1 * x2 + x2 * x2 - 8 * x1 - 12 * x2;
}

// Одномерная минимизация 
double line_search(double y1, double y2, double d1, double d2) {
    double x1 = y1, x2 = y2;

    // Первые производные 
    double fx = 6 * x1 + 2 * x2 - 8;
    double fy = 2 * x1 + 2 * x2 - 12;

    // Вторые производные 
    double fxx = 6, fyy = 2, fxy = 2;

    double a = fxx * d1 * d1 + 2 * fxy * d1 * d2 + fyy * d2 * d2;
    double b = fx * d1 + fy * d2;

    if (a > 0) {
        return -b / (2 * a);
    }
    return 0;
}

bool check_rank(double d1[2], double d2[2]) {
    double det = d1[0] * d2[1] - d1[1] * d2[0];
    return fabs(det) > 1e-8;
}

int main() {
    setlocale(LC_ALL, "Russian");

    // Шаг 1
    double xk[2] = { 1, 2 };
    double epsilon = 0.1;

    double d0[2] = { 1, 0 };
    double d1[2] = { 0, 1 };
    double d2[2] = { 1, 0 };

    int n = 2;
    int i = 0;
    int k = 0;
    int iteration = 0;

    double y0[2] = { xk[0], xk[1] };
    double y1[2], y2[2], y3[2];

    cout << "Начальная точка: (" << xk[0] << ", " << xk[1] << ")" << endl;
    cout << "Начальное значение функции: " << f(xk[0], xk[1]) << endl;

    while (true) {
        iteration++;
        cout << "\n Итерация " << iteration << endl;

        //Шаг 1
        double t0 = line_search(y0[0], y0[1], d0[0], d0[1]);
        y1[0] = y0[0] + t0 * d0[0];
        y1[1] = y0[1] + t0 * d0[1];
        //Шаг 2(0)
        //cout << "Поиск по d0 = (" << d0[0] << ", " << d0[1] << ")" << endl;
        cout << "  t0 = " << t0 << ", y1 = (" << y1[0] << ", " << y1[1] << ")" << endl;
        cout << "  f(y1) = " << f(y1[0], y1[1]) << endl;


        // Шаг 2(1)
        double t1 = line_search(y1[0], y1[1], d1[0], d1[1]);
        y2[0] = y1[0] + t1 * d1[0];
        y2[1] = y1[1] + t1 * d1[1];
        //cout << "Поиск по d1 = (" << d1[0] << ", " << d1[1] << ")" << endl;
        cout << "  t1 = " << t1 << ", y2 = (" << y2[0] << ", " << y2[1] << ")" << endl;
        cout << "  f(y2) = " << f(y2[0], y2[1]) << endl;

        // Шаг 3(а)
        i = 2;

        // Шаг 2(2)
        double t2 = line_search(y2[0], y2[1], d2[0], d2[1]);
        y3[0] = y2[0] + t2 * d2[0];
        y3[1] = y2[1] + t2 * d2[1];
        //cout << "Поиск по d2 = (" << d2[0] << ", " << d2[1] << ")" << endl;
        cout << "  t2 = " << t2 << ", y3 = (" << y3[0] << ", " << y3[1] << ")" << endl;
        cout << "  f(y3) = " << f(y3[0], y3[1]) << endl;

        // Шаг 3(в)
        if (fabs(y3[0] - y1[0]) < 1e-8 && fabs(y3[1] - y1[1]) < 1e-8) {
            cout << "\nПоиск завершён: y3 == y1" << endl;
            cout << "x* = (" << y3[0] << ", " << y3[1] << ")" << endl;
            cout << "f(x*) = " << f(y3[0], y3[1]) << endl;
            break;
        }

        // Шаг 4
        double x_next[2] = { y3[0], y3[1] };

        double delta = sqrt(pow(x_next[0] - xk[0], 2) + pow(x_next[1] - xk[1], 2));
        cout << "\nНовая точка x^{" << k + 1 << "} = (" << x_next[0] << ", " << x_next[1] << ")" << endl;
        cout << "||x^{k+1} - x^k|| = " << delta << endl;

        if (delta < epsilon) {
            cout << "\nУсловие окончания выполнено" << endl;
            cout << "x* = (" << x_next[0] << ", " << x_next[1] << ")" << endl;
            cout << "f(x*) = " << f(x_next[0], x_next[1]) << endl;
            break;
        }

        // Строим новое направление
        double d_new[2] = { y3[0] - y1[0], y3[1] - y1[1] };
        cout << "Новое направление d_new = (" << d_new[0] << ", " << d_new[1] << ")" << endl;

        // Исключаем старое направление
        d0[0] = d1[0]; d0[1] = d1[1];
        d1[0] = d2[0]; d1[1] = d2[1];
        d2[0] = d_new[0]; d2[1] = d_new[1];

        if (check_rank(d1, d2)) {
            cout << "Система направлений линейно независима (ранг = 2)" << endl;
        }
        else {
            cout << "Cистема направлений линейно зависима (ранг < 2)" << endl;
        }

        xk[0] = x_next[0];
        xk[1] = x_next[1];
        y0[0] = xk[0];
        y0[1] = xk[1];

        k++;
        i = 0;

        if (iteration > 10) {
            cout << "\nПревышено максимальное число итераций" << endl;
            break;
        }
    }

    return 0;
}
